# This .gitignore file is template for Unity projects.
# Source: https://github.com/github/gitignore/blob/main/Unity.gitignore

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[MemoryCaptures]/

# Asset meta files may contain information about imported assets; major version control
# systems have built in support for such files so they should not be ignored.
# !/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset database cache
# /[Aa]ssets/AssetStoreTools*

# Visual Studio cache and settings
.vs/
[Dd]ebug/
[Rr]elease/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
